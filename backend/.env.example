# ═══════════════════════════════════════════════════════════════
#  CommitChain Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── API Keys (maintainer secrets — NEVER share) ─────────────
GEMINI_API_KEY=your_gemini_api_key_here
PINATA_JWT=your_pinata_jwt_here

# ─── Security ────────────────────────────────────────────────
# Optional: require this key in X-API-Key header for all requests
# Leave empty to allow public access (rate-limited)
API_SECRET_KEY=

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=30

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated allowed origins (empty = allow all)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
